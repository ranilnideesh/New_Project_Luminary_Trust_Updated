}

/* NAVBAR */

nav{
position:fixed;
top:0;
width:100%;
background:#111;
padding:18px 60px;
display:flex;
justify-content:space-between;
align-items:center;
z-index:1000;
}

.logo{
color:#c9a96e;
font-size:28px;
font-weight:700;
text-decoration:none;
font-family:'Cormorant Garamond',serif;
}

.logo span{
color:white;
}

.nav-links{
display:flex;
list-style:none;
gap:25px;
}

.nav-links a{
text-decoration:none;
color:white;
font-size:14px;
transition:0.3s;
}

.nav-links a:hover{
color:#c9a96e;
}

.donate-btn{
background:#c9a96e;
padding:10px 18px;
border-radius:4px;
color:#111 !important;
font-weight:600;
}

.hamburger{
display:none;
flex-direction:column;
gap:5px;
cursor:pointer;
}

.hamburger span{
width:26px;
height:2px;
