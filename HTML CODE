}

/* HERO */

.hero{
min-height:100vh;
background:
linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
url('https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=1600&q=80');
background-size:cover;
background-position:center;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:120px 20px;
color:white;
}

.hero h1{
font-size:72px;
line-height:1.1;
margin-bottom:20px;
font-family:'Cormorant Garamond',serif;
}

.hero h1 span{
color:#c9a96e;
}

.hero p{
max-width:700px;
margin:auto;
font-size:18px;
margin-bottom:30px;
}

.small-title{
text-transform:uppercase;
letter-spacing:3px;
color:#c9a96e;
font-size:13px;
margin-bottom:15px;
}

.btn,
.btn-outline{
display:inline-block;
padding:14px 30px;
margin:10px;
text-decoration:none;
text-transform:uppercase;
font-size:13px;
letter-spacing:2px;
transition:0.3s;
}

.btn{
background:#c9a96e;
color:#111;
}

.btn:hover{
transform:translateY(-3px);
}

.btn-outline{
border:1px solid white;
color:white;
}

.btn-outline:hover{
background:white;
color:#111;
}

/* IMPACT */

.impact{
display:grid;
grid-template-columns:repeat(4,1fr);
background:white;
}

.impact div{
padding:50px 20px;
text-align:center;
border-right:1px solid #eee;
}

.impact h2{
font-size:42px;
color:#c9a96e;
margin-bottom:10px;
}

/* GENERAL */

.section{
padding:100px 70px;
max-width:1200px;
margin:auto;
}

.section h2{
font-size:45px;
margin-bottom:20px;
font-family:'Cormorant Garamond',serif;
color:#111;
}

.two-col{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.card{
background:white;
padding:35px;
border:1px solid #eee;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
transition:0.3s;
}

.card:hover{
transform:translateY(-8px);
}

.light{
background:white;
max-width:100%;
}

.grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:25px;
margin-top:35px;
}

.card h3{
margin-bottom:15px;
color:#111;
}

.card a{
display:inline-block;
margin-top:20px;
text-decoration:none;
color:#c9a96e;
font-weight:600;
}

/* PAGE HERO */

.page-hero{
padding:150px 30px 90px;
text-align:center;
background:
linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
url('https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=1600&q=80');
background-size:cover;
background-position:center;
color:white;
}

.page-hero h1{
font-size:56px;
margin-bottom:15px;
font-family:'Cormorant Garamond',serif;
}

/* BARS */

.bar{
margin:25px 0;
}

.bar span{
display:block;
margin-bottom:8px;
font-weight:600;
}

.bar div{
height:10px;
background:#ddd;
border-radius:20px;
overflow:hidden;
}

.bar p{
height:100%;
background:#c9a96e;
}

/* FORMS */

.form-section{
padding:100px 30px;
}

form{
max-width:650px;
margin:auto;
background:white;
padding:40px;
display:flex;
flex-direction:column;
gap:18px;
box-shadow:0 20px 40px rgba(0,0,0,0.08);
}

input,
select,
textarea{
padding:15px;
border:1px solid #ddd;
font-size:15px;
font-family:'Inter',sans-serif;
}

textarea{
min-height:130px;
}

button{
padding:15px;
border:none;
background:#c9a96e;
color:#111;
font-weight:700;
cursor:pointer;
}

/* FOOTER */

footer{
background:#111;
color:white;
text-align:center;
padding:30px;
}

/* MOBILE */

@media(max-width:768px){

nav{
padding:18px 25px;
}

.hamburger{
display:flex;
}

.nav-links{
position:fixed;
top:70px;
right:-100%;
width:100%;
height:calc(100vh - 70px);
background:#111;
flex-direction:column;
justify-content:center;
align-items:center;
transition:0.4s;
}

.nav-links.active{
right:0;
}

.hero h1{
font-size:40px;
}

.impact,
.two-col,
.grid{
grid-template-columns:1fr;
}

.section{
padding:70px 25px;
}

.page-hero h1{
font-size:38px;
}

form{
padding:25px;
}

}

</style>
</head>

